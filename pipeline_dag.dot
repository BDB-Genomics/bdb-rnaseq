digraph RNAseqPipeline {
    rankdir=TB;
    size="14,20";
    node [shape=box, style=rounded, fontname=Helvetica];

    // ===== EXISTING RULES =====
    subgraph cluster_existing {
        label="EXISTING RULES";
        color="#4472C4";
        style=filled;

        INPUT [label="INPUT\nFASTQ + Config + Samples", fillcolor="#70AD47", fontcolor=white];

        fastp [label="fastp\nTrim adapters", fillcolor="#4472C4", fontcolor=white];
        fastqc [label="fastqc\nQuality check", fillcolor="#4472C4", fontcolor=white];
        star_align [label="star_align\nSplice-aware alignment", fillcolor="#4472C4", fontcolor=white];
        samtools_sort [label="samtools_sort\nSort BAM", fillcolor="#4472C4", fontcolor=white];
        samtools_index [label="samtools_index\nIndex BAM", fillcolor="#4472C4", fontcolor=white];
        samtools_stats [label="samtools_stats\nAlignment stats", fillcolor="#4472C4", fontcolor=white];
        featurecounts [label="featurecounts\nGene quantification", fillcolor="#4472C4", fontcolor=white];
        qc_gate [label="qc_gate\nQC threshold", fillcolor="#4472C4", fontcolor=white];
        multiqc [label="multiqc\nAggregate QC", fillcolor="#4472C4", fontcolor=white];
    }

    // ===== MISSING RULES =====
    subgraph cluster_missing {
        label="MISSING RULES (Need to be added)";
        color="#C00000";
        style=filled;
        fontcolor="#C00000";

        duplicate_marking [label="duplicate_marking\npicard MarkDuplicates", fillcolor="#C00000", fontcolor=white, style=dashed];
        rnaseq_metrics [label="rnaseq_metrics\npicard CollectRnaSeqMetrics", fillcolor="#C00000", fontcolor=white, style=dashed];
        bam_coverage [label="bam_coverage\ndeepTools bamCoverage", fillcolor="#C00000", fontcolor=white, style=dashed];
        qualimap [label="qualimap\nbamqc", fillcolor="#C00000", fontcolor=white, style=dashed];
        preseq [label="preseq\nc_curve", fillcolor="#C00000", fontcolor=white, style=dashed];
    }

    // ===== CURRENT FLOW =====
    INPUT -> fastp;
    INPUT -> fastqc;
    fastp -> fastqc;
    fastp -> star_align;
    fastqc -> star_align;
    star_align -> samtools_sort;
    samtools_sort -> samtools_index;
    samtools_index -> samtools_stats;
    samtools_stats -> featurecounts;
    samtools_stats -> qc_gate;
    featurecounts -> multiqc;
    qc_gate -> multiqc;

    // ===== MISSING CONNECTIONS =====
    samtools_sort -> duplicate_marking [color="#C00000", style=dashed];
    duplicate_marking -> rnaseq_metrics [color="#C00000", style=dashed];
    rnaseq_metrics -> bam_coverage [color="#C00000", style=dashed];
    samtools_stats -> qualimap [color="#C00000", style=dashed];
    bam_coverage -> multiqc [color="#C00000", style=dashed];

    // ===== OUTPUT LEGEND =====
    subgraph cluster_outputs {
        label="CURRENT OUTPUTS";
        color="#70AD47";
        style=filled;

        // fastp outputs
        fastp_out1 [label="fastp output:\n_R1_trimmed.fastq.gz\n_R2_trimmed.fastq.gz\n.json, .html", shape=note, fillcolor="#E2EFDA"];

        // fastqc outputs
        fastqc_out1 [label="fastqc output:\n_fastqc.html\n_fastqc.zip", shape=note, fillcolor="#E2EFDA"];

        // star outputs
        star_out1 [label="star output:\nAligned.out.bam\nLog.final.out\nReadsPerGene.out.tab", shape=note, fillcolor="#E2EFDA"];

        // samtools_sort output
        sort_out1 [label="samtools_sort output:\n.sorted.bam", shape=note, fillcolor="#E2EFDA"];

        // samtools_index output
        index_out1 [label="samtools_index output:\n.sorted.bam.bai", shape=note, fillcolor="#E2EFDA"];

        // samtools_stats output
        stats_out1 [label="samtools_stats output:\n_postFiltering.stats.txt", shape=note, fillcolor="#E2EFDA"];

        // featurecounts output
        fc_out1 [label="featurecounts output:\ncounts.txt\ncounts.txt.summary", shape=note, fillcolor="#E2EFDA"];

        // qc_gate output
        qc_out1 [label="qc_gate output:\n_qc_pass.txt / _qc_fail.txt", shape=note, fillcolor="#E2EFDA"];

        // multiqc output
        mqc_out1 [label="multiqc output:\nmultiqc_report.html", shape=note, fillcolor="#E2EFDA"];

        // Connect outputs to rules
        fastp -> fastp_out1 [style=invis];
        fastqc -> fastqc_out1 [style=invis];
        star_align -> star_out1 [style=invis];
        samtools_sort -> sort_out1 [style=invis];
        samtools_index -> index_out1 [style=invis];
        samtools_stats -> stats_out1 [style=invis];
        featurecounts -> fc_out1 [style=invis];
        qc_gate -> qc_out1 [style=invis];
        multiqc -> mqc_out1 [style=invis];
    }

    // ===== LEGEND =====
    Legend [label="LEGEND\n\n✅ Blue = Existing Rule\n❌ Red Dashed = Missing Rule\n📄 Green Note = Output File", shape=box, fillcolor="#F5F5F5", fontsize=10];
}